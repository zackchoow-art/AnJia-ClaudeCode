# ============================================================================
# REDP Phase 0 - Git Ignore Rules
# ============================================================================

# 环境变量 (重要!永远不能提交)
.env
.env.local
.env.*.local
!.env.example

# 密钥和凭证
*.pem
*.key
*.crt
secrets/
credentials/

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Deno
.deno/
deno.lock

# Supabase
supabase/.branches
supabase/.temp
.supabase/

# 编辑器和IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 操作系统
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 测试
coverage/
.nyc_output/
*.test.log

# 构建产物
dist/
build/
out/
.next/

# 日志
logs/
*.log
npm-debug.log*

# 临时文件
tmp/
temp/
*.tmp
*.bak

# Worktree (按需保留)
# worktrees/  # 不忽略,提交所有worktree的元数据

# 私人备注
NOTES.md
TODO.local.md

# REDP特定
.redp/cache/
.logs/raw/
