# ============================================================================
# REDP Phase 0 - 环境变量配置模板
# 复制到 .env 并填入实际值
# 警告: .env 永远不要提交到Git!
# ============================================================================

# --- Supabase配置 ---
# 从Supabase Dashboard > Settings > API获取
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...  # 公开的anon key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # 服务端key, 不要泄露!
SUPABASE_DB_PASSWORD=your_database_password
SUPABASE_PROJECT_ID=your_project_id

# 数据库连接字符串(自动从上面构建)
SUPABASE_CONNECTION_STRING=postgresql://postgres:${SUPABASE_DB_PASSWORD}@db.${SUPABASE_PROJECT_ID}.supabase.co:5432/postgres

# --- Nvidia NIM API ---
# 从 build.nvidia.com/settings/api-keys 获取
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Agent模型配置 ---
AGENT_COMMANDER_MODEL=qwen/qwen3-coder-480b-a35b-instruct
AGENT_DATA_ANALYST_MODEL=nvidia/nemotron-3-nano-30b-a3b
AGENT_UI_DESIGNER_MODEL=nvidia/nemotron-3-super-120b-a12b
AGENT_FULLSTACK_STANDARD_MODEL=minimaxai/minimax-m2.7
AGENT_FULLSTACK_SENIOR_MODEL=qwen/qwen3-coder-480b-a35b-instruct
AGENT_FULLSTACK_ASSISTANT_MODEL=nvidia/nemotron-3-nano-30b-a3b
AGENT_REVIEWER_MODEL=minimaxai/minimax-m2.7
AGENT_TESTER_MODEL=nvidia/nemotron-3-super-120b-a12b

# --- Hermes Configuration ---
HERMES_WORKTREE_ROOT=./worktrees
HERMES_TASK_DIR=./.redp/tasks
HERMES_LOG_DIR=./.logs
HERMES_MAX_PARALLEL_AGENTS=5
HERMES_AGENT_TIMEOUT_SECONDS=3600
HERMES_RETRY_ATTEMPTS=3
HERMES_RETRY_DELAY_SECONDS=60

# --- Application Settings ---
APP_ENV=development  # development, staging, production
APP_LOG_LEVEL=info
APP_DEFAULT_LOCALE=zh-CN
APP_DEFAULT_TIMEZONE=Asia/Shanghai
APP_DEFAULT_CURRENCY=CNY

# --- Security ---
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.com
JWT_SECRET=generate_a_strong_random_secret_here  # openssl rand -hex 32

# --- Optional: 外部服务 ---
# UYGHUR_TRANSLATION_API_KEY=  (Phase 1后再启用)
# CONTRACT_OCR_API_KEY=  (Phase 1后再启用)
